<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" nodeOrientation="LEFT_TO_RIGHT" prefHeight="450.0" prefWidth="350.0" spacing="12.0" style="-fx-background-color: #1E293B;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.navegacionforumulariosfx.HelloController">

    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
    </padding>

    <children>

        <Label text="Login" textFill="WHITE">
            <font>
                <Font name="System Bold" size="27.0" />
            </font>
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
        </Label>

        <Label alignment="CENTER_LEFT" maxWidth="Infinity" text="Usuario" textFill="WHITE">
         <font>
            <Font name="System Bold" size="21.0" />
         </font></Label>

        <TextField fx:id="txtUsuario" prefWidth="250.0" promptText="Ingrese su usuario" />

        <Label alignment="CENTER_LEFT" maxWidth="Infinity" text="Contraseña" textFill="WHITE">
         <font>
            <Font name="System Bold" size="21.0" />
         </font></Label>


        <PasswordField fx:id="txtContrasena" prefWidth="250.0" promptText="Ingrese su contraseña" />

        <Label alignment="CENTER_LEFT" maxWidth="Infinity" text="Rol" />
      <ComboBox fx:id="cmbRol" prefWidth="150.0" />

        <HBox alignment="CENTER" spacing="15.0">

            <children>
                <Button onAction="#btnIngresar" prefWidth="110.0" text="Ingresar" />

                <Button onAction="#btnSalir" prefWidth="110.0" text="Salir" />
            </children>

            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>

        </HBox>
      <Label fx:id="lblmsj" />

    </children>

</VBox>
